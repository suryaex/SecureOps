{
  "appId": "id.ac.polsri.secureops",
  "appName": "SecureOps",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "cleartext": true,
    "allowNavigation": ["*"]
  },
  "android": {
    "buildOptions": {
      "keystorePath": "android/keystore/secureops.keystore",
      "keystoreAlias": "secureops",
      "releaseType": "APK"
    }
  },
  "ios": {
    "contentInset": "always",
    "limitsNavigationsToAppBoundDomains": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#2563EB",
      "androidSplashResourceName": "splash",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#2563EB"
    }
  }
}
